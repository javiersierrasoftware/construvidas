{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/events/layout,_N_T_/events/request/layout,_N_T_/events/request/page,_N_T_/events/request"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/events/request/__PAGE__",
    "/events/request",
    "/events",
    "/_index",
    "/_head"
  ]
}