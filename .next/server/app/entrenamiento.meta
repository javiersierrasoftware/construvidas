{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/entrenamiento/layout,_N_T_/entrenamiento/page,_N_T_/entrenamiento"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
